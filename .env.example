# Copy to .env (or export in your shell) and fill in real values.

# Flask session signing key — change in production
SECRET_KEY=change-me-to-a-random-string

# Database URL (default: SQLite at instance/app.db)
# DATABASE_URL=sqlite:///instance/app.db
# DATABASE_URL=mysql+pymysql://user:pass@host:3306/socialpulse
# DATABASE_URL=postgresql://user:pass@host:5432/socialpulse

# Apify API token (optional — leave blank to use synthetic sample data)
APIFY_API_TOKEN=

# Override default actors if you have access to better ones
# APIFY_TWITTER_ACTOR=apidojo/twitter-scraper-lite
# APIFY_FACEBOOK_ACTOR=apify/facebook-posts-scraper
